<?xml version="1.0"?>
<launch>
    <!-- Node namespace / vehicle name. Relative topic args below resolve under this. -->
    <arg name="robot_name" default="lolo" description="Vehicle name; node namespace. Relative topics resolve as /{robot_name}/..."/>
    <arg name="use_sim_time" default="false" description="Use simulation clock"/>

    <!-- The serial link to the modem / Teensy bridge is owned by the
         succorfish_driver node; launch it separately (pick the matching profile)
         or in the same namespace so RX/TX/SendCommand line up. Set start_driver:=true
         to bring one up here, in this node's namespace, for a single-node run. -->
    <arg name="start_driver" default="false" description="Also launch succorfish_driver in this node's namespace"/>
    <arg name="driver_profile" default="teensy" description="Driver profile: teensy (115200/ttyACM) or succorfish (9600/ttyUSB)"/>
    <arg name="driver_namespace" default="$(var robot_name)" description="Namespace for the driver (defaults to robot_name, matching the node)"/>
    <arg name="driver_backend" default="serial" description="Driver I/O backend: serial (real port), test (in-memory modem) or unity (smarcUnity bridge)"/>
    <arg name="unity_own_modem_id" default="001" description="(unity backend) this modem id stamped on transmitted packets"/>
    <arg name="unity_write_topic" default="acoustic/write" description="(unity backend) StringStamped topic the driver publishes (Unity transmitter listens)"/>
    <arg name="unity_read_topic" default="acoustic/read" description="(unity backend) StringStamped topic the driver subscribes (Unity receiver publishes)"/>
    <arg name="unity_offset_us" default="0.0" description="(unity backend) microseconds added to the derived OWTT delta"/>
    <include file="$(find-pkg-share succorfish_driver)/launch/succorfish_driver.launch" if="$(var start_driver)">
        <arg name="profile" value="$(var driver_profile)"/>
        <arg name="namespace" value="$(var driver_namespace)"/>
        <arg name="backend" value="$(var driver_backend)"/>
        <arg name="unity_own_modem_id" value="$(var unity_own_modem_id)"/>
        <arg name="unity_write_topic" value="$(var unity_write_topic)"/>
        <arg name="unity_read_topic" value="$(var unity_read_topic)"/>
        <arg name="unity_offset_us" value="$(var unity_offset_us)"/>
    </include>


    <!-- Teensy bridge / payload limits -->
    <arg name="enable_wire_on_startup" default="true" description="Put a Teensy bridge into transparent wire mode on startup (harmless for raw modems)"/>
    <arg name="own_modem_id" default="007" description="This node's own modem address"/>
    <arg name="command_terminator" default="&#13;&#10;" description="Terminator appended to serial commands"/>
    <arg name="payload_max_bytes" default="64" description="Max broadcast/unicast payload size in bytes"/>

    <!-- Ping task behaviour -->
    <arg name="ping_max_retries" default="3" description="Retries after the first attempt per modem"/>
    <arg name="ping_response_timeout_s" default="3.0" description="Per-ping response timeout (s)"/>
    <arg name="ping_task_timeout_s" default="180.0" description="Overall ping task timeout (s)"/>
    <arg name="ping_cycle_until_estimated" default="true" description="Keep cycling pings until each modem is localized"/>

    <!-- Estimator selection and sound velocity -->
    <arg name="estimator_method" default="least_squares" description="least_squares | ekf"/>
    <arg name="default_sound_velocity" default="1500.0" description="Fallback sound velocity (m/s): 1500 water, ~330 air"/>
    <arg name="sound_velocity_topic" default="/lolo/sensors/svs" description="Live sound-velocity topic (empty disables)"/>
    <arg name="sound_velocity_msg_type" default="svs_interfaces/msg/SVS" description="Sound-velocity message type"/>
    <arg name="sound_velocity_field" default="svs" description="Field on the message holding the velocity"/>

    <!-- Estimator noise model -->
    <arg name="range_sigma_m" default="1.0" description="Range measurement std (m)"/>
    <arg name="own_position_sigma_m" default="1.0" description="Own-position std (m)"/>
    <arg name="own_depth_sigma_m" default="0.3" description="Own-depth std (m)"/>
    <arg name="remote_depth_sigma_m" default="0.5" description="Remote (modem) depth std (m)"/>
    <arg name="use_known_remote_depth" default="true" description="Fix remote z from per-modem known depth when available"/>
    <arg name="min_measurements" default="4" description="Minimum ranges before estimating"/>
    <arg name="max_measurements" default="40" description="Sliding-window size of ranges kept"/>
    <arg name="max_position_uncertainty_m" default="5.0" description="Publish estimate once sigma drops below this (m)"/>

    <!-- Least-squares tuning -->
    <arg name="ls_max_iterations" default="20" description="Gauss-Newton iterations"/>
    <arg name="ls_damping" default="0.001" description="Levenberg-Marquardt damping"/>
    <arg name="ls_outlier_gate_m" default="10.0" description="Residual gate for one-pass outlier rejection (m); 0 disables"/>

    <!-- EKF tuning -->
    <arg name="ekf_process_noise_std_m" default="0.05" description="Static random-walk process noise std (m)"/>
    <arg name="ekf_initial_sigma_xy_m" default="50.0" description="Initial XY std (m)"/>
    <arg name="ekf_initial_sigma_z_m" default="2.0" description="Initial Z std (m)"/>

    <!-- Topics / frames (relative names resolve under robot_name) -->
    <arg name="own_latlon_topic" default="smarc/latlon" description="Own lat/lon input topic"/>
    <arg name="own_depth_topic" default="smarc/depth" description="Own depth input topic (empty disables)"/>
    <arg name="own_position_max_age_s" default="3.0" description="Discard own position older than this (s)"/>
    <arg name="geopoint_topic" default="modem_estimates/geopoint" description="Estimated modem position output topic"/>
    <arg name="marker_topic" default="modem_estimates/rviz" description="RViz MarkerArray output topic"/>
    <arg name="map_frame" default="M350/map" description="World/map frame for RViz markers"/>

    <node pkg="serial_ping_pkg"
          exec="ping_estimator_action_node"
          name="ping_estimator_action_node"
          output="screen"
          namespace="$(var robot_name)">

        <param name="robot_name" type="str" value="$(var robot_name)"/>
        <param name="use_sim_time" value="$(var use_sim_time)"/>

        <param name="teensy.enable_wire_on_startup" value="$(var enable_wire_on_startup)"/>
        <param name="teensy.own_modem_id" type="str" value="$(var own_modem_id)"/>
        <param name="teensy.command_terminator" type="str" value="$(var command_terminator)"/>
        <param name="teensy.payload_max_bytes" value="$(var payload_max_bytes)"/>

        <param name="ping.max_retries" value="$(var ping_max_retries)"/>
        <param name="ping.response_timeout_s" value="$(var ping_response_timeout_s)"/>
        <param name="ping.task_timeout_s" value="$(var ping_task_timeout_s)"/>
        <param name="ping.cycle_until_estimated" value="$(var ping_cycle_until_estimated)"/>

        <param name="estimator.method" type="str" value="$(var estimator_method)"/>
        <param name="estimator.default_sound_velocity" value="$(var default_sound_velocity)"/>
        <param name="estimator.sound_velocity_topic" type="str" value="$(var sound_velocity_topic)"/>
        <param name="estimator.sound_velocity_msg_type" type="str" value="$(var sound_velocity_msg_type)"/>
        <param name="estimator.sound_velocity_field" type="str" value="$(var sound_velocity_field)"/>

        <param name="estimator.range_sigma_m" value="$(var range_sigma_m)"/>
        <param name="estimator.own_position_sigma_m" value="$(var own_position_sigma_m)"/>
        <param name="estimator.own_depth_sigma_m" value="$(var own_depth_sigma_m)"/>
        <param name="estimator.remote_depth_sigma_m" value="$(var remote_depth_sigma_m)"/>
        <param name="estimator.use_known_remote_depth" value="$(var use_known_remote_depth)"/>
        <param name="estimator.min_measurements" value="$(var min_measurements)"/>
        <param name="estimator.max_measurements" value="$(var max_measurements)"/>
        <param name="estimator.max_position_uncertainty_m" value="$(var max_position_uncertainty_m)"/>

        <param name="estimator.least_squares.max_iterations" value="$(var ls_max_iterations)"/>
        <param name="estimator.least_squares.damping" value="$(var ls_damping)"/>
        <param name="estimator.least_squares.outlier_gate_m" value="$(var ls_outlier_gate_m)"/>

        <param name="estimator.ekf.process_noise_std_m" value="$(var ekf_process_noise_std_m)"/>
        <param name="estimator.ekf.initial_sigma_xy_m" value="$(var ekf_initial_sigma_xy_m)"/>
        <param name="estimator.ekf.initial_sigma_z_m" value="$(var ekf_initial_sigma_z_m)"/>

        <param name="topics.own_latlon_topic" type="str" value="$(var own_latlon_topic)"/>
        <param name="topics.own_depth_topic" type="str" value="$(var own_depth_topic)"/>
        <param name="topics.own_position_max_age_s" value="$(var own_position_max_age_s)"/>
        <param name="topics.geopoint_topic" type="str" value="$(var geopoint_topic)"/>
        <param name="topics.marker_topic" type="str" value="$(var marker_topic)"/>
        <param name="topics.map_frame" type="str" value="$(var map_frame)"/>
    </node>
</launch>
